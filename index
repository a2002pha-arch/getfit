<!-- WORKOUT SCREEN (fullscreen) -->
<div id="workout-screen" style="display:none;position:fixed;inset:0;background:var(--bg);z-index:300;overflow-y:auto;flex-direction:column;">
  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--border);background:rgba(10,10,15,.95);backdrop-filter:blur(10px);position:sticky;top:0;z-index:10;">
    <button onclick="exitWorkout()" style="padding:8px 16px;border-radius:99px;border:1.5px solid var(--border);background:transparent;color:var(--muted);font-family:Cairo,sans-serif;font-size:13px;cursor:pointer;">✕ إنهاء</button>
    <div style="text-align:center;">
      <div style="font-size:11px;color:var(--muted)" id="wk-prog-name">—</div>
      <div style="font-size:13px;font-weight:700;color:var(--text)" id="wk-day-name">—</div>
    </div>
    <div style="font-size:12px;font-weight:700;color:var(--accent)" id="wk-counter">0/0</div>
  </div>

  <!-- Exercise display -->
  <div style="flex:1;display:flex;flex-direction:column;align-items:center;padding:20px 16px 100px;max-width:500px;margin:0 auto;width:100%;">
    <!-- GIF -->
    <div style="width:100%;border-radius:20px;overflow:hidden;background:var(--surface);border:1px solid var(--border);margin-bottom:20px;aspect-ratio:1;display:flex;align-items:center;justify-content:center;position:relative;">
      <img id="wk-gif" src="" alt="" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none';document.getElementById('wk-gif-fallback').style.display='flex'"/>
      <div id="wk-gif-fallback" style="display:none;position:absolute;inset:0;align-items:center;justify-content:center;font-size:80px;">💪</div>
    </div>

    <!-- Exercise name & sets -->
    <div style="text-align:center;margin-bottom:24px;width:100%;">
      <div style="font-family:Tajawal,sans-serif;font-size:24px;font-weight:800;color:var(--white);margin-bottom:6px;" id="wk-ex-name">—</div>
      <div style="font-size:14px;color:var(--muted);" id="wk-sets-info">—</div>
    </div>

    <!-- Timer circle -->
    <div style="position:relative;width:160px;height:160px;margin-bottom:28px;">
      <svg width="160" height="160" viewBox="0 0 160 160" style="transform:rotate(-90deg)">
        <circle cx="80" cy="80" r="70" fill="none" stroke="var(--border)" stroke-width="10"/>
        <circle id="wk-timer-ring" cx="80" cy="80" r="70" fill="none" stroke="url(#timerGrad)" stroke-width="10" stroke-linecap="round"
