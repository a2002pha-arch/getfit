/* ══ PROGRAMS ══ */
.programs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:24px;}
.program-card{background:var(--surface);border:1.5px solid var(--border);border-radius:20px;overflow:hidden;cursor:pointer;transition:all .25s;}
.program-card:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(108,99,255,.2);}
.program-card.active-prog{border-color:var(--accent);box-shadow:0 0 0 2px rgba(108,99,255,.3);}
.prog-header{padding:18px;background:linear-gradient(135deg,var(--card),var(--surface));}
.prog-icon{font-size:36px;margin-bottom:8px;}
.prog-name{font-family:'Tajawal',sans-serif;font-size:18px;font-weight:800;color:var(--white);margin-bottom:4px;}
.prog-desc{font-size:12px;color:var(--muted);line-height:1.5;}
.prog-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;}
.prog-tag{font-size:10px;padding:3px 9px;border-radius:99px;font-weight:700;background:rgba(108,99,255,.15);color:var(--accent);border:1px solid rgba(108,99,255,.3);}
.prog-footer{padding:12px 18px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.prog-weeks{font-size:11px;color:var(--muted);}
.prog-start-btn{padding:7px 16px;border-radius:99px;border:none;background:var(--accent);color:#fff;font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;}
.prog-start-btn.started{background:var(--green);}
.active-prog-wrap{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:20px;margin-bottom:20px;display:none;}
.active-prog-wrap.show{display:block;}
.apw-header{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.apw-icon{font-size:32px;}.apw-info{flex:1;}
.apw-name{font-family:'Tajawal',sans-serif;font-size:18px;font-weight:800;color:var(--white);}
.apw-week{font-size:12px;color:var(--accent);margin-top:2px;}
.apw-progress{height:6px;background:var(--border);border-radius:99px;overflow:hidden;margin-bottom:16px;}
.apw-progress-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--accent),var(--green));transition:width .5s;}
.week-days{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;}
.week-day{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:8px 4px;text-align:center;cursor:pointer;transition:all .2s;}
.week-day:hover{border-color:var(--accent);}
.week-day.today-wd{border-color:var(--accent);background:rgba(108,99,255,.1);}
.week-day.done-wd{border-color:var(--green);background:rgba(0,212,170,.1);}
.week-day.rest-wd{opacity:.5;cursor:default;}
.wd-name{font-size:9px;color:var(--muted);margin-bottom:3px;}
.wd-icon{font-size:18px;}.wd-status{font-size:8px;margin-top:2px;color:var(--muted);}
.workout-session{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:20px;display:none;margin-top:16px;}
.workout-session.show{display:block;}
.ws-header{display:flex;align-items:center;gap:12px;margin-bottom:18px;flex-wrap:wrap;}
.ws-title{font-family:'Tajawal',sans-serif;font-size:18px;font-weight:800;color:var(--white);flex:1;}
.ws-close{padding:7px 14px;border-radius:99px;border:1.5px solid var(--border);background:transparent;color:var(--muted);font-family:'Cairo',sans-serif;font-size:12px;cursor:pointer;}
.ws-exercises{display:flex;flex-direction:column;gap:10px;margin-bottom:20px;}
.ws-ex{background:var(--card);border:1.5px solid var(--border);border-radius:14px;padding:14px;display:flex;align-items:center;gap:12px;transition:all .2s;cursor:pointer;}
.ws-ex.done-ex{border-color:var(--green);background:rgba(0,212,170,.08);}
.ws-ex-num{width:28px;height:28px;border-radius:50%;background:var(--border);color:var(--muted);font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;}
.ws-ex.done-ex .ws-ex-num{background:var(--green);color:#fff;}
.ws-ex-info{flex:1;}
.ws-ex-name{font-size:13px;font-weight:700;color:var(--white);}
.ws-ex-detail{font-size:11px;color:var(--muted);margin-top:2px;}
.ws-finish-btn{width:100%;padding:14px;border-radius:14px;border:none;background:linear-gradient(135deg,var(--green),#00b894);color:#fff;font-family:'Cairo',sans-serif;font-size:15px;font-weight:800;cursor:pointer;}

/* ══ PROGRESS ══ */
.progress-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:20px;}
.ps-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;text-align:center;}
.ps-val{font-family:'Tajawal',sans-serif;font-size:28px;font-weight:900;color:var(--accent);}
.ps-lbl{font-size:11px;color:var(--muted);margin-top:4px;}
.progress-calendar{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:16px;}
.pc-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:12px;}
.pc-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-bottom:6px;}
.pc-day{aspect-ratio:1;border-radius:6px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--muted);}
.pc-day.worked{background:linear-gradient(135deg,var(--accent),var(--green));border-color:transparent;color:#fff;font-weight:800;}
.pc-day.today-cal{border-color:var(--orange);color:var(--orange);}
.achievements{display:flex;flex-direction:column;gap:10px;}
.achievement{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px;display:flex;align-items:center;gap:12px;}
.achievement.unlocked{border-color:var(--orange);background:rgba(255,159,67,.06);}
.ach-icon{font-size:28px;flex-shrink:0;}
.ach-info{flex:1;}
.ach-name{font-size:13px;font-weight:700;color:var(--white);}
.ach-desc{font-size:11px;color:var(--muted);margin-top:2px;}
.ach-badge{font-size:10px;padding:3px 9px;border-radius:99px;font-weight:700;}
.ach-badge.unlocked{background:rgba(255,159,67,.2);color:var(--orange);border:1px solid rgba(255,159,67,.3);}
.ach-badge.locked{background:var(--card);color:var(--muted);border:1px solid var(--border);}{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}

/* Page header */
.page-header{margin-bottom:22px;}
.page-header .tag{font-size:10px;letter-spacing:4px;color:var(--accent);font-family:'Tajawal',sans-serif;margin-bottom:6px;}
.page-header h2{font-family:'Tajawal',sans-serif;font-weight:800;font-size:22px;color:var(--white);}
</style>
</head>
