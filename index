<!-- ══ SETUP ══ -->
<div class="page active" id="page-setup">
  <div class="setup-hero">
    <span class="emoji">🔥</span>
    <h1>حاسبة السعرات</h1>
    <p>احسب احتياجك اليومي وتتبع وجباتك بسهولة</p>
  </div>

  <div class="setup-card">
    <h3>👤 بياناتك الشخصية</h3>
    <div class="form-row">
      <div class="form-field">
        <label>العمر (سنة)</label>
        <input type="number" id="s-age" placeholder="25" min="10" max="100"/>
      </div>
      <div class="form-field">
        <label>الجنس</label>
        <select id="s-gender">
          <option value="male">ذكر</option>
          <option value="female">أنثى</option>
        </select>
      </div>
      <div class="form-field">
        <label>الطول (سم)</label>
        <input type="number" id="s-height" placeholder="175" min="100" max="250"/>
      </div>
      <div class="form-field">
        <label>الوزن الحالي (كجم)</label>
        <input type="number" id="s-weight" placeholder="80" min="30" max="300" step="0.1"/>
      </div>
      <div class="form-field full">
        <label>الوزن المستهدف (كجم)</label>
        <input type="number" id="s-target" placeholder="70" min="30" max="300" step="0.1"/>
      </div>
    </div>
  </div>

  <div class="setup-card">
    <h3>🏃 مستوى النشاط</h3>
    <div class="activity-grid">
      <button class="activity-btn" data-val="1.2" onclick="selActivity(this)">😴 خامل جداً<br/><span style="font-size:10px;opacity:.6">بدون رياضة</span></button>
      <button class="activity-btn" data-val="1.375" onclick="selActivity(this)">🚶 خفيف<br/><span style="font-size:10px;opacity:.6">1-3 أيام/أسبوع</span></button>
      <button class="activity-btn sel" data-val="1.55" onclick="selActivity(this)">🏋️ متوسط<br/><span style="font-size:10px;opacity:.6">3-5 أيام/أسبوع</span></button>
      <button class="activity-btn" data-val="1.725" onclick="selActivity(this)">⚡ نشيط<br/><span style="font-size:10px;opacity:.6">6-7 أيام/أسبوع</span></button>
    </div>
  </div>

  <button class="calc-btn" onclick="calcCalories()">🔥 احسب السعرات اليومية</button>

  <div class="result-box" id="result-box">
    <div style="font-size:12px;color:var(--muted);margin-bottom:6px">سعراتك اليومية الموصى بها</div>
    <div class="result-cals" id="result-cals">—</div>
    <div class="result-label">سعرة حرارية / يوم</div>
    <div class="result-breakdown">
      <div class="rb-item"><div class="rb-val" id="rb-protein" style="color:#6c63ff">—</div><div class="rb-lbl">بروتين (جم)</div></div>
      <div class="rb-item"><div class="rb-val" id="rb-carbs" style="color:#ff9f43">—</div><div class="rb-lbl">كربوهيدرات (جم)</div></div>
      <div class="rb-item"><div class="rb-val" id="rb-fat" style="color:#ff6584">—</div><div class="rb-lbl">دهون (جم)</div></div>
    </div>
    <button class="save-setup-btn" onclick="saveSetup()">✅ حفظ وابدأ التتبع</button>
  </div>
</div>

<!-- ══ TODAY ══ -->
<div class="page" id="page-today">
  <div class="today-header">
    <div class="today-date" id="today-date">—</div>
    <div class="today-title">وجبات اليوم 🍽️</div>
  </div>

  <!-- Calorie Ring -->
  <div class="cal-ring-wrap">
    <div class="cal-ring">
      <svg viewBox="0 0 120 120">
        <defs>
          <linearGradient id="calGrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:#6c63ff"/>
            <stop offset="100%" style="stop-color:#ff6584"/>
          </linearGradient>
        </defs>
        <circle class="ring-track" cx="60" cy="60" r="50"/>
        <circle class="ring-fill" id="ring-fill" cx="60" cy="60" r="50" stroke-dasharray="314" stroke-dashoffset="314"/>
      </svg>
      <div class="ring-text">
        <div class="ring-remaining" id="ring-remaining">—</div>
        <div class="ring-label">متبقي</div>
      </div>
    </div>
    <div class="cal-stats">
      <div class="cal-stat-row">
        <span class="cal-stat-name">الهدف</span>
        <span class="cal-stat-val goal" id="stat-goal">—</span>
      </div>
      <div class="cal-stat-row">
        <span class="cal-stat-name">مُستهلك</span>
        <span class="cal-stat-val eaten" id="stat-eaten">0</span>
      </div>
      <div class="cal-stat-row">
        <span class="cal-stat-name">متبقي</span>
        <span class="cal-stat-val remaining" id="stat-remaining">—</span>
      </div>
    </div>
  </div>

  <!-- Macros -->
  <div class="macros-card">
    <h3>📊 الماكروز</h3>
    <div class="macro-row">
      <div class="macro-head"><span class="macro-name" style="color:#6c63ff">💪 بروتين</span><span class="macro-val" id="mac-protein">0 / — جم</span></div>
      <div class="macro-bar-bg"><div class="macro-bar" id="mac-bar-protein" style="width:0%;background:#6c63ff"></div></div>
    </div>
    <div class="macro-row">
      <div class="macro-head"><span class="macro-name" style="color:#ff9f43">🌾 كربوهيدرات</span><span class="macro-val" id="mac-carbs">0 / — جم</span></div>
      <div class="macro-bar-bg"><div class="macro-bar" id="mac-bar-carbs" style="width:0%;background:#ff9f43"></div></div>
    </div>
    <div class="macro-row" style="margin-bottom:0">
      <div class="macro-head"><span class="macro-name" style="color:#ff6584">🥑 دهون</span><span class="macro-val" id="mac-fat">0 / — جم</span></div>
      <div class="macro-bar-bg"><div class="macro-bar" id="mac-bar-fat" style="width:0%;background:#ff6584"></div></div>
    </div>
  </div>

  <!-- Meals -->
  <div class="meals-section">
    <h3>الوجبات المسجّلة <span id="meals-count" style="color:var(--accent)"></span></h3>
    <div id="meals-list"></div>
    <button class="add-meal-btn" onclick="openAddMeal()">➕ إضافة وجبة</button>
  </div>
</div>

<!-- ══ FOODS ══ -->
<div class="page" id="page-foods">
  <div class="page-header">
    <div class="tag">🥗 قاعدة البيانات</div>
    <h2>الأطعمة والوجبات</h2>
  </div>

  <div class="food-search">
    <input type="text" id="food-search-inp" placeholder="ابحث عن طعام..." oninput="renderFoodDB()"/>
