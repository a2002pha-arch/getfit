const ACHIEVEMENTS=[
  {id:'first',icon:'🌱',name:'الخطوة الأولى',desc:'أكمل أول تمرين',req:1},
  {id:'streak3',icon:'🔥',name:'ثلاثة متتالية',desc:'3 أيام متتالية',req:3,streak:true},
  {id:'ten',icon:'💪',name:'عاشر تمرين',desc:'أكمل 10 تمارين',req:10},
  {id:'week1',icon:'⭐',name:'أسبوع كامل',desc:'7 أيام متتالية',req:7,streak:true},
  {id:'thirty',icon:'🏆',name:'بطل الشهر',desc:'30 تمرين',req:30},
  {id:'fifty',icon:'💎',name:'خمسون تمريناً',desc:'أكمل 50 تمرين',req:50},
];
function renderProgressPage(){
  const logs=Object.keys(workoutLog);const total=logs.length;
  const uniqueDays=[...new Set(logs.map(k=>k.split('_')[0]))].sort();
  const today=new Date();const todayStr=today.toISOString().split('T')[0];
  let streak=0;
  for(let i=0;i<uniqueDays.length;i++){
    const d=uniqueDays[uniqueDays.length-1-i];
    const diff=Math.floor((today-new Date(d))/(1000*60*60*24));
    if(diff===i)streak++;else break;
  }
  let best=0,cur=1;
  for(let i=1;i<uniqueDays.length;i++){
    const a=new Date(uniqueDays[i-1]),b=new Date(uniqueDays[i]);
    if(Math.round((b-a)/(1000*60*60*24))===1){cur++;best=Math.max(best,cur);}else cur=1;
  }
  const weekStart=new Date(today);weekStart.setDate(today.getDate()-today.getDay());
  const thisWeek=uniqueDays.filter(d=>new Date(d)>=weekStart).length;
  document.getElementById('pr-total').textContent=total;
  document.getElementById('pr-streak').textContent=streak;
  document.getElementById('pr-week').textContent=thisWeek;
  document.getElementById('pr-best').textContent=Math.max(best,streak);
  // Calendar
  document.getElementById('pc-days-labels').innerHTML=['أ','إ','ث','أر','خ','ج','س'].map(l=>`<div class="pc-day" style="background:transparent;border-color:transparent;color:var(--muted);font-size:9px;font-weight:700">${l}</div>`).join('');
  const days=[];for(let i=83;i>=0;i--){const d=new Date(today);d.setDate(d.getDate()-i);days.push(d);}
  document.getElementById('pc-grid').innerHTML=days.map(d=>{
    const k=d.toISOString().split('T')[0];
    return`<div class="pc-day ${uniqueDays.includes(k)?'worked':''} ${k===todayStr?'today-cal':''}">${d.getDate()}</div>`;
  }).join('');
  // Achievements
  document.getElementById('achievements-list').innerHTML=ACHIEVEMENTS.map(a=>{
    const val=a.streak?streak:total;const unlocked=val>=a.req;
    return`<div class="achievement ${unlocked?'unlocked':''}">
      <span class="ach-icon">${a.icon}</span><div class="ach-info"><div class="ach-name">${a.name}</div><div class="ach-desc">${a.desc}</div></div>
      <span class="ach-badge ${unlocked?'unlocked':'locked'}">${unlocked?'✅ مفتوح':`${val}/${a.req}`}</span></div>`;
  }).join('');
}

