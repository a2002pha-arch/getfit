        <div style="padding:14px 16px;display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;border-radius:10px;background:${isRest?'var(--card)':isDone?'rgba(0,212,170,.15)':isToday?'rgba(108,99,255,.15)':'var(--card)'};display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">${isDone?'✅':isRest?'😴':isToday?'⚡':'💪'}</div>
          <div style="flex:1">
