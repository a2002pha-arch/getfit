let activeMuscleCat=Object.keys(EXERCISES)[0];

function renderExercises(){
  const tabs=document.getElementById('muscle-tabs');
  const content=document.getElementById('exercises-content');
  tabs.innerHTML=Object.entries(EXERCISES).map(([k,v])=>
    `<button class="muscle-tab ${k===activeMuscleCat?'active':''}" onclick="setMuscleCat('${k}',this)">${v.icon} ${v.name}</button>`
  ).join('');
  const cat=EXERCISES[activeMuscleCat];
  const homeCount=cat.exercises.filter(e=>e.home).length;
  content.innerHTML=`<div class="muscle-section">
    <div class="muscle-header">
      <span class="muscle-icon">${cat.icon}</span>
      <span class="muscle-title">تمارين ${cat.name}</span>
      <span class="muscle-count">${cat.exercises.length} تمرين</span>
      ${homeCount?`<span class="home-badge">🏠 ${homeCount} منزلي</span>`:''}
    </div>
    <div class="exercises-grid">
      ${cat.exercises.map(ex=>`<div class="ex-card">
        <img class="ex-img" src="${ex.img}" alt="${ex.name}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
        <div class="ex-img-placeholder" style="display:none">${cat.icon}</div>
        <div class="ex-body">
          <div class="ex-name">${ex.name}</div>
          <div class="ex-tags">
            <span class="ex-tag muscle">💪 ${ex.muscle}</span>
            <span class="ex-tag equip">🏋️ ${ex.equip}</span>
            <span class="ex-tag level">${ex.level==='مبتدئ'?'🟢':ex.level==='متوسط'?'🟡':'🔴'} ${ex.level}</span>
            ${ex.home?'<span class="ex-tag home">🏠 منزلي</span>':''}
          </div>
          <div class="ex-desc">${ex.desc}</div>
          <div class="ex-sets">
            <div class="ex-set-item"><div class="ex-set-val">${ex.sets}</div><div class="ex-set-lbl">سيت</div></div>
            <div class="ex-set-item"><div class="ex-set-val">${ex.reps}</div><div class="ex-set-lbl">تكرار</div></div>
          </div>
        </div>
      </div>`).join('')}
    </div>
  </div>`;
}

function setMuscleCat(k,btn){
  activeMuscleCat=k;
  document.querySelectorAll('.muscle-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderExercises();
}
</script>
</body>
</html>
