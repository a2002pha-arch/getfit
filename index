let wkState={progId:null,dayIdx:null,exercises:[],currentEx:0,currentSet:1,timer:null,timeLeft:45,isRunning:false,startTime:null,totalTime:0};
const REST_TIME=20;const EXERCISE_TIME=45;

function openWorkoutScreen(progId,dayIdx,day){
  wkState={progId,dayIdx,exercises:day.exercises,currentEx:0,currentSet:1,timer:null,timeLeft:EXERCISE_TIME,isRunning:false,startTime:Date.now(),totalTime:0};
  const prog=PROGRAMS.find(p=>p.id===progId);
  document.getElementById('wk-prog-name').textContent=prog?prog.name:'';
  document.getElementById('wk-day-name').textContent=day.name;
  document.getElementById('workout-screen').style.display='flex';
  document.body.style.overflow='hidden';
  updateWorkoutUI();
}

function updateWorkoutUI(){
  const ex=wkState.exercises[wkState.currentEx];if(!ex)return;
  // Counter
  document.getElementById('wk-counter').textContent=`${wkState.currentEx+1}/${wkState.exercises.length}`;
  // GIF — search in EXERCISES data
  let gif='';
  for(const cat of Object.values(EXERCISES)){
    const found=cat.exercises.find(e=>e.name===ex.name);
    if(found){gif=found.img;break;}
  }
  const imgEl=document.getElementById('wk-gif');
  const fallEl=document.getElementById('wk-gif-fallback');
  if(gif){imgEl.src=gif;imgEl.style.display='block';fallEl.style.display='none';}
  else{imgEl.style.display='none';fallEl.style.display='flex';}
  // Name & sets
  document.getElementById('wk-ex-name').textContent=ex.name;
  document.getElementById('wk-sets-info').textContent=`السيت ${wkState.currentSet} من ${ex.sets} · ${ex.reps} تكرار`;
  // Mini list
  document.getElementById('wk-ex-list').innerHTML=wkState.exercises.map((e,i)=>`
    <div style="display:flex;align-items:center;gap:10px;padding:8px;border-radius:8px;background:${i===wkState.currentEx?'rgba(108,99,255,.12)':'transparent'};border:1px solid ${i===wkState.currentEx?'var(--accent)':'transparent'};">
      <span style="font-size:11px;font-weight:700;color:${i<wkState.currentEx?'var(--green)':i===wkState.currentEx?'var(--accent)':'var(--muted)'};width:18px">${i<wkState.currentEx?'✓':i+1}</span>
      <span style="font-size:12px;color:${i===wkState.currentEx?'var(--white)':'var(--muted)'};flex:1">${e.name}</span>
      <span style="font-size:10px;color:var(--muted)">${e.sets}×${e.reps}</span>
    </div>`).join('');
  // Reset timer
  resetTimer();
}

function resetTimer(){
  clearInterval(wkState.timer);
  wkState.isRunning=false;
  wkState.timeLeft=EXERCISE_TIME;
  document.getElementById('wk-play-btn').textContent='▶';
  document.getElementById('wk-rest-banner').style.display='none';
  updateTimerDisplay();
}

function updateTimerDisplay(){
  const t=wkState.timeLeft;
  document.getElementById('wk-timer-num').textContent=t;
  const C=439.8;
  const maxTime=wkState.isRest?REST_TIME:EXERCISE_TIME;
  document.getElementById('wk-timer-ring').style.strokeDashoffset=C*(1-t/maxTime);
}

function toggleTimer(){
  if(wkState.isRunning){
    clearInterval(wkState.timer);wkState.isRunning=false;
    document.getElementById('wk-play-btn').textContent='▶';
  } else {
    wkState.isRunning=true;
    document.getElementById('wk-play-btn').textContent='⏸';
    wkState.timer=setInterval(()=>{
      wkState.timeLeft--;
      updateTimerDisplay();
      if(wkState.timeLeft<=0){
        clearInterval(wkState.timer);wkState.isRunning=false;
        document.getElementById('wk-play-btn').textContent='▶';
        if(wkState.isRest){wkState.isRest=false;document.getElementById('wk-rest-banner').style.display='none';updateWorkoutUI();}
        else autoNextSet();
      }
    },1000);
  }
}

function autoNextSet(){
  const ex=wkState.exercises[wkState.currentEx];
  if(wkState.currentSet<ex.sets){
    wkState.currentSet++;
    wkState.isRest=true;wkState.timeLeft=REST_TIME;
    document.getElementById('wk-rest-banner').style.display='block';
    document.getElementById('wk-sets-info').textContent=`السيت ${wkState.currentSet} من ${ex.sets} · ${ex.reps} تكرار`;
    updateTimerDisplay();
    // Auto-start rest
    wkState.isRunning=true;document.getElementById('wk-play-btn').textContent='⏸';
    wkState.timer=setInterval(()=>{wkState.timeLeft--;updateTimerDisplay();if(wkState.timeLeft<=0){clearInterval(wkState.timer);wkState.isRunning=false;document.getElementById('wk-play-btn').textContent='▶';wkState.isRest=false;document.getElementById('wk-rest-banner').style.display='none';wkState.timeLeft=EXERCISE_TIME;updateTimerDisplay();}},1000);
  } else {
    nextExercise();
  }
}

function nextExercise(){
  clearInterval(wkState.timer);wkState.isRest=false;
  if(wkState.currentEx>=wkState.exercises.length-1){finishWorkoutScreen();return;}
  wkState.currentEx++;wkState.currentSet=1;
  updateWorkoutUI();toast('✅ انتقلنا للتمرين التالي','ok');
}

function prevExercise(){
  clearInterval(wkState.timer);wkState.isRest=false;
  if(wkState.currentEx<=0)return;
  wkState.currentEx--;wkState.currentSet=1;
  updateWorkoutUI();
}

function finishWorkoutScreen(){
  clearInterval(wkState.timer);
  const dur=Math.round((Date.now()-wkState.startTime)/60000);
  // Save log
  const key=new Date().toISOString().split('T')[0]+'_'+wkState.progId+'_'+wkState.dayIdx;
  workoutLog[key]={date:new Date().toISOString(),progId:wkState.progId,dayIdx:wkState.dayIdx,duration:dur};
  saveWorkoutLog();
  document.getElementById('workout-screen').style.display='none';
  document.body.style.overflow='';
  // Show finish screen
  document.getElementById('fin-excount').textContent=wkState.exercises.length;
  document.getElementById('fin-duration').textContent=dur||1;
  const fs=document.getElementById('finish-screen');
  fs.style.display='flex';
  renderProgressPage();
}

function exitWorkout(){
  if(!confirm('إنهاء التمرين؟'))return;
  clearInterval(wkState.timer);
  document.getElementById('workout-screen').style.display='none';
  document.body.style.overflow='';
}

function closeFinish(){
  document.getElementById('finish-screen').style.display='none';
  showPage('programs',document.querySelectorAll('.nav-btn')[4]);
  renderPrograms();
}

