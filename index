<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>حاسبة السعرات</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;700;800;900&family=Cairo:wght@400;600;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#0a0a0f;--surface:#12121a;--card:#1a1a26;--border:#2a2a3a;
  --accent:#6c63ff;--accent2:#ff6584;--green:#00d4aa;--orange:#ff9f43;
  --text:#e8e8f0;--muted:#6b6b8a;--white:#ffffff;
  --cal-color:#6c63ff;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Cairo',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(108,99,255,.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 80%,rgba(255,101,132,.06) 0%,transparent 60%);pointer-events:none;z-index:0;}

/* NAV */
.nav{position:sticky;top:0;z-index:100;background:rgba(10,10,15,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;justify-content:center;gap:4px;padding:10px 14px;flex-wrap:wrap;}
.nav-btn{padding:8px 16px;border-radius:99px;border:1.5px solid var(--border);background:transparent;color:var(--muted);font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;}
.nav-btn:hover{border-color:var(--accent);color:var(--accent);}
.nav-btn.active{background:var(--accent);border-color:var(--accent);color:#fff;}

/* PAGES */
.page{display:none;padding:24px 14px 80px;position:relative;z-index:1;max-width:680px;margin:0 auto;}
.page.active{display:block;}

/* SETUP PAGE */
.setup-hero{text-align:center;padding:30px 0 24px;}
.setup-hero .emoji{font-size:64px;margin-bottom:12px;display:block;}
.setup-hero h1{font-family:'Tajawal',sans-serif;font-weight:900;font-size:clamp(24px,5vw,38px);background:linear-gradient(135deg,var(--white),var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px;}
.setup-hero p{color:var(--muted);font-size:14px;}

.setup-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:20px;margin-bottom:16px;}
.setup-card h3{font-size:14px;font-weight:700;color:var(--accent);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
.form-field{display:flex;flex-direction:column;gap:6px;}
.form-field.full{grid-column:1/-1;}
.form-field label{font-size:11px;color:var(--muted);font-weight:700;letter-spacing:.5px;}
.form-field input,.form-field select{background:var(--card);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-family:'Cairo',sans-serif;font-size:14px;padding:10px 13px;outline:none;transition:border-color .2s;}
.form-field input:focus,.form-field select:focus{border-color:var(--accent);}
.form-field select option{background:var(--card);}
.activity-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
.activity-btn{padding:10px 8px;border-radius:12px;border:1.5px solid var(--border);background:var(--card);color:var(--muted);font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;transition:all .2s;text-align:center;}
.activity-btn:hover{border-color:var(--accent);color:var(--accent);}
.activity-btn.sel{border-color:var(--accent);background:rgba(108,99,255,.15);color:var(--accent);}
.calc-btn{width:100%;padding:14px;border-radius:14px;border:none;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;font-family:'Cairo',sans-serif;font-size:15px;font-weight:800;cursor:pointer;transition:transform .15s,opacity .2s;margin-top:8px;}
.calc-btn:hover{transform:translateY(-1px);opacity:.9;}
.result-box{background:linear-gradient(135deg,rgba(108,99,255,.15),rgba(255,101,132,.1));border:1px solid rgba(108,99,255,.3);border-radius:16px;padding:20px;margin-top:16px;text-align:center;display:none;}
.result-box.show{display:block;}
.result-cals{font-family:'Tajawal',sans-serif;font-size:48px;font-weight:900;color:var(--accent);line-height:1;}
.result-label{font-size:13px;color:var(--muted);margin-top:4px;}
.result-breakdown{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:16px;}
.rb-item{background:var(--card);border-radius:10px;padding:10px;text-align:center;}
.rb-val{font-family:'Tajawal',sans-serif;font-size:18px;font-weight:800;}
.rb-lbl{font-size:10px;color:var(--muted);margin-top:2px;}
.save-setup-btn{width:100%;padding:13px;border-radius:14px;border:none;background:linear-gradient(135deg,var(--green),#00b894);color:#fff;font-family:'Cairo',sans-serif;font-size:14px;font-weight:800;cursor:pointer;margin-top:12px;transition:opacity .2s;}
.save-setup-btn:hover{opacity:.9;}

/* TODAY PAGE */
.today-header{margin-bottom:20px;}
.today-date{font-size:12px;color:var(--muted);margin-bottom:4px;}
.today-title{font-family:'Tajawal',sans-serif;font-size:22px;font-weight:800;color:var(--white);}

/* Calorie ring */
.cal-ring-wrap{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:20px;margin-bottom:16px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
.cal-ring{position:relative;width:120px;height:120px;flex-shrink:0;}
.cal-ring svg{transform:rotate(-90deg);width:100%;height:100%);}
.cal-ring .ring-track{fill:none;stroke:var(--border);stroke-width:10;}
.cal-ring .ring-fill{fill:none;stroke:url(#calGrad);stroke-width:10;stroke-linecap:round;transition:stroke-dashoffset .8s cubic-bezier(.4,0,.2,1);}
.cal-ring .ring-text{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.ring-remaining{font-family:'Tajawal',sans-serif;font-size:20px;font-weight:900;color:var(--white);line-height:1;}
.ring-label{font-size:9px;color:var(--muted);margin-top:2px;}
.cal-stats{flex:1;min-width:120px;}
.cal-stat-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);}
.cal-stat-row:last-child{border-bottom:none;}
.cal-stat-name{font-size:12px;color:var(--muted);}
.cal-stat-val{font-family:'Tajawal',sans-serif;font-size:16px;font-weight:800;}
.cal-stat-val.goal{color:var(--accent);}
.cal-stat-val.eaten{color:var(--green);}
.cal-stat-val.remaining{color:var(--orange);}
.cal-stat-val.burned{color:var(--accent2);}

/* Meals list */
.meals-section{margin-bottom:16px;}
.meals-section h3{font-size:13px;font-weight:700;color:var(--muted);margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
.meal-item{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;animation:fadeIn .2s ease;}
.meal-icon{font-size:24px;flex-shrink:0;}
.meal-info{flex:1;}
.meal-name{font-size:13px;font-weight:700;color:var(--white);}
.meal-time{font-size:10px;color:var(--muted);margin-top:2px;}
.meal-cals{font-family:'Tajawal',sans-serif;font-size:16px;font-weight:800;color:var(--accent);flex-shrink:0;}
.meal-del{background:none;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:4px;transition:color .15s;}
.meal-del:hover{color:var(--accent2);}
.empty-meals{text-align:center;padding:30px 20px;color:var(--muted);font-size:13px;}
.empty-meals .em-icon{font-size:36px;margin-bottom:8px;}

/* Add meal button */
.add-meal-btn{width:100%;padding:13px;border-radius:14px;border:1.5px dashed var(--border);background:transparent;color:var(--muted);font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:7px;}
.add-meal-btn:hover{border-color:var(--accent);color:var(--accent);}

/* Macros bar */
.macros-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:16px;}
.macros-card h3{font-size:13px;font-weight:700;color:var(--muted);margin-bottom:12px;}
.macro-row{margin-bottom:10px;}
.macro-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.macro-name{font-size:12px;font-weight:600;}
.macro-val{font-size:11px;color:var(--muted);}
.macro-bar-bg{height:6px;background:var(--border);border-radius:99px;overflow:hidden;}
.macro-bar{height:100%;border-radius:99px;transition:width .6s cubic-bezier(.4,0,.2,1);}

/* FOOD DB PAGE */
.food-search{position:relative;margin-bottom:16px;}
.food-search input{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:14px;color:var(--text);font-family:'Cairo',sans-serif;font-size:14px;padding:12px 42px 12px 16px;outline:none;transition:border-color .2s;}
.food-search input:focus{border-color:var(--accent);}
.food-search .search-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:16px;}
.food-category{margin-bottom:20px;}
.food-category h3{font-size:12px;font-weight:700;color:var(--accent);letter-spacing:2px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border);}
.food-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;}
.food-card{background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:12px;cursor:pointer;transition:all .2s;}
.food-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 6px 20px rgba(108,99,255,.15);}
.food-card.selected{border-color:var(--green);background:rgba(0,212,170,.08);}
.food-emoji{font-size:28px;margin-bottom:6px;}
.food-name{font-size:12px;font-weight:700;color:var(--white);margin-bottom:2px;}
.food-cals-badge{font-family:'Tajawal',sans-serif;font-size:14px;font-weight:800;color:var(--accent);}
.food-per{font-size:10px;color:var(--muted);}
.custom-food-add{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:16px;}
.custom-food-add h3{font-size:13px;font-weight:700;color:var(--muted);margin-bottom:12px;}
.custom-row{display:grid;grid-template-columns:2fr 1fr 1fr;gap:10px;align-items:end;}
.add-food-btn{padding:10px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:opacity .2s;}
.add-food-btn:hover{opacity:.85;}

/* HISTORY PAGE */
.history-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px;}
.hs-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px;text-align:center;}
.hs-val{font-family:'Tajawal',sans-serif;font-size:22px;font-weight:900;color:var(--accent);}
.hs-lbl{font-size:10px;color:var(--muted);margin-top:3px;}
.history-list{display:flex;flex-direction:column;gap:10px;}
.history-item{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px;display:flex;align-items:center;gap:14px;}
.hi-date{font-size:11px;color:var(--muted);flex-shrink:0;min-width:55px;text-align:center;}
.hi-date .day{font-family:'Tajawal',sans-serif;font-size:20px;font-weight:800;color:var(--white);display:block;}
.hi-bar-wrap{flex:1;}
.hi-title{font-size:12px;font-weight:700;color:var(--white);margin-bottom:5px;}
.hi-bar-bg{height:8px;background:var(--border);border-radius:99px;overflow:hidden;}
.hi-bar{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .6s;}
.hi-cals{font-family:'Tajawal',sans-serif;font-size:16px;font-weight:800;flex-shrink:0;text-align:left;}
.hi-status{font-size:10px;margin-top:2px;}

/* MODAL */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.85);backdrop-filter:blur(8px);z-index:200;display:flex;align-items:flex-end;justify-content:center;padding:16px;}
.modal-bg.hidden{display:none;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:24px 24px 16px 16px;padding:24px;width:100%;max-width:480px;max-height:85vh;overflow-y:auto;}
.modal h3{font-size:16px;font-weight:700;color:var(--white);margin-bottom:16px;}
.modal-search{margin-bottom:14px;}
.modal-search input{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-family:'Cairo',sans-serif;font-size:13px;padding:10px 12px;outline:none;}
.modal-search input:focus{border-color:var(--accent);}
.modal-food-list{display:flex;flex-direction:column;gap:7px;margin-bottom:14px;max-height:280px;overflow-y:auto;}
.modal-food-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--card);border:1.5px solid var(--border);border-radius:10px;cursor:pointer;transition:all .15s;}
.modal-food-item:hover,.modal-food-item.sel{border-color:var(--accent);background:rgba(108,99,255,.1);}
.mfi-emoji{font-size:20px;flex-shrink:0;}
.mfi-name{flex:1;font-size:13px;font-weight:600;}
.mfi-cals{font-family:'Tajawal',sans-serif;font-size:14px;font-weight:800;color:var(--accent);}
.qty-row{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.qty-row label{font-size:12px;color:var(--muted);font-weight:600;white-space:nowrap;}
.qty-input{flex:1;background:var(--card);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-family:'Cairo',sans-serif;font-size:14px;padding:9px 12px;outline:none;text-align:center;}
.qty-input:focus{border-color:var(--accent);}
.meal-time-select{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-family:'Cairo',sans-serif;font-size:13px;padding:9px 12px;outline:none;margin-bottom:14px;}
.modal-btns{display:flex;gap:10px;}
.modal-add{flex:1;padding:12px;border-radius:12px;border:none;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;font-family:'Cairo',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:opacity .2s;}
.modal-add:hover{opacity:.85;}
.modal-cancel{padding:12px 16px;border-radius:12px;border:1.5px solid var(--border);background:transparent;color:var(--muted);font-family:'Cairo',sans-serif;font-size:13px;cursor:pointer;}

/* ══ EXERCISES ══ */
.muscle-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;}
.muscle-tab{padding:8px 16px;border-radius:99px;border:1.5px solid var(--border);background:var(--surface);color:var(--muted);font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px;}
.muscle-tab:hover{border-color:var(--accent);color:var(--accent);}
.muscle-tab.active{background:var(--accent);border-color:var(--accent);color:#fff;}
.home-badge{background:rgba(0,212,170,.15);border:1px solid rgba(0,212,170,.3);color:var(--green);font-size:9px;padding:2px 6px;border-radius:99px;font-weight:700;}
.exercises-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;}
.ex-card{background:var(--surface);border:1.5px solid var(--border);border-radius:18px;overflow:hidden;transition:all .25s;cursor:pointer;}
.ex-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 8px 28px rgba(108,99,255,.15);}
.ex-img{width:100%;height:180px;object-fit:cover;background:var(--card);display:block;}
.ex-img-placeholder{width:100%;height:180px;background:linear-gradient(135deg,var(--card),var(--surface));display:flex;align-items:center;justify-content:center;font-size:48px;}
.ex-body{padding:14px;}
.ex-name{font-size:14px;font-weight:700;color:var(--white);margin-bottom:6px;}
.ex-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;}
.ex-tag{font-size:10px;padding:3px 8px;border-radius:99px;font-weight:700;}
.ex-tag.muscle{background:rgba(108,99,255,.15);color:var(--accent);border:1px solid rgba(108,99,255,.3);}
.ex-tag.equip{background:rgba(255,159,67,.15);color:var(--orange);border:1px solid rgba(255,159,67,.3);}
.ex-tag.home{background:rgba(0,212,170,.15);color:var(--green);border:1px solid rgba(0,212,170,.3);}
.ex-tag.level{background:rgba(255,101,132,.15);color:var(--accent2);border:1px solid rgba(255,101,132,.3);}
.ex-desc{font-size:11px;color:var(--muted);line-height:1.6;}
.ex-sets{display:flex;gap:10px;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);}
.ex-set-item{text-align:center;flex:1;}
.ex-set-val{font-family:'Tajawal',sans-serif;font-size:16px;font-weight:800;color:var(--accent);}
.ex-set-lbl{font-size:10px;color:var(--muted);}
.muscle-section{margin-bottom:10px;}
.muscle-header{display:flex;align-items:center;gap:10px;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border);}
.muscle-icon{font-size:28px;}
.muscle-title{font-family:'Tajawal',sans-serif;font-size:20px;font-weight:800;color:var(--white);}
.muscle-count{font-size:11px;color:var(--muted);background:var(--card);padding:3px 10px;border-radius:99px;border:1px solid var(--border);}
