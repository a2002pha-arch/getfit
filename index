function backToProgList(){
  viewingProg=null;
  document.getElementById('prog-list-view').style.display='block';
  document.getElementById('prog-detail-view').style.display='none';
}

function startProgram(id){
  if(workoutProg&&!confirm('تبديل البرنامج الحالي؟'))return;
  workoutProg={id,startDate:new Date().toISOString().split('T')[0]};
  saveWorkoutProg();viewProgram(id);toast('🎉 تم بدء البرنامج!','ok');
}

function stopProgram(){
  if(!confirm('إيقاف البرنامج؟'))return;
  workoutProg=null;saveWorkoutProg();backToProgList();renderPrograms();
}

function startTodayWorkout(progId){
  const prog=PROGRAMS.find(p=>p.id===progId);if(!prog)return;
  const today=new Date().getDay();
  const day=prog.schedule[today];
  if(!day||day.type==='rest'){toast('😴 اليوم راحة — لا يوجد تمرين',true);return;}
  openWorkoutScreen(progId,today,day);
}

