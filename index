  {id:'f24',cat:'🍔 المطاعم والوجبات السريعة',emoji:'🌮',name:'شاورما دجاج',cals:420,protein:28,carbs:38,fat:14},
  {id:'f25',cat:'🍔 المطاعم والوجبات السريعة',emoji:'🍟',name:'بطاطس مقلية (وسط)',cals:340,protein:4,carbs:44,fat:16},
