function initFoods(){
  if(!foodDB){foodDB=JSON.parse(JSON.stringify(DEFAULT_FOODS));saveFood();}
}
function saveFood(){localStorage.setItem(SK.foods,JSON.stringify(foodDB));}
function saveLog(){localStorage.setItem(SK.log,JSON.stringify(log));}
function saveSetupData(){localStorage.setItem(SK.setup,JSON.stringify(setup));}

// ══ HELPERS ════════════════════════════════════════════
function todayKey(){return new Date().toISOString().split('T')[0];}
function fmtDate(d){return new Date(d).toLocaleDateString('ar-SA',{weekday:'short',day:'numeric',month:'short'});}
function nowTime(){return new Date().toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'});}

// ══ SETUP ══════════════════════════════════════════════
function selActivity(btn){
  document.querySelectorAll('.activity-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  selectedActivity=parseFloat(btn.dataset.val);
}
function calcCalories(){
  const age=parseInt(document.getElementById('s-age').value);
  const gender=document.getElementById('s-gender').value;
  const height=parseFloat(document.getElementById('s-height').value);
  const weight=parseFloat(document.getElementById('s-weight').value);
  const target=parseFloat(document.getElementById('s-target').value);
  if(!age||!height||!weight){toast('❌ عبّ كل البيانات','err');return;}
  // Mifflin-St Jeor formula
  let bmr;
  if(gender==='male')bmr=10*weight+6.25*height-5*age+5;
  else bmr=10*weight+6.25*height-5*age-161;
  let tdee=Math.round(bmr*selectedActivity);
  // Adjust for goal (lose: -500)
  let goal=tdee-500;
  if(target>weight)goal=tdee+300; // gain
  goal=Math.max(1200,goal);
  const protein=Math.round(weight*2);
  const fat=Math.round(goal*0.25/9);
  const carbs=Math.round((goal-protein*4-fat*9)/4);
  document.getElementById('result-cals').textContent=goal;
  document.getElementById('rb-protein').textContent=protein;
  document.getElementById('rb-carbs').textContent=carbs;
  document.getElementById('rb-fat').textContent=fat;
  document.getElementById('result-box').classList.add('show');
  document.getElementById('result-box').scrollIntoView({behavior:'smooth',block:'center'});
  // Store temp
  window._tempSetup={goal,protein,carbs,fat,weight,height,age,gender,target};
}
function saveSetup(){
  if(!window._tempSetup){toast('❌ احسب السعرات أولاً','err');return;}
  setup={...window._tempSetup,savedAt:new Date().toISOString()};
  saveSetupData();
  toast('✅ تم الحفظ! انتقل لصفحة اليوم','ok');
  setTimeout(()=>{
    document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.nav-btn')[1].classList.add('active');
    showPage('today',document.querySelectorAll('.nav-btn')[1]);
  },1200);
}
function loadSetupUI(){
  if(!setup)return;
  document.getElementById('s-age').value=setup.age||'';
  document.getElementById('s-height').value=setup.height||'';
  document.getElementById('s-weight').value=setup.weight||'';
  document.getElementById('s-target').value=setup.target||'';
  document.getElementById('s-gender').value=setup.gender||'male';
  window._tempSetup=setup;
  document.getElementById('result-cals').textContent=setup.goal;
  document.getElementById('rb-protein').textContent=setup.protein;
  document.getElementById('rb-carbs').textContent=setup.carbs;
  document.getElementById('rb-fat').textContent=setup.fat;
  document.getElementById('result-box').classList.add('show');
}

// ══ TODAY ═══════════════════════════════════════════════
function renderToday(){
  const key=todayKey();
  const dayLog=log[key]||{meals:[]};
  const goal=setup?setup.goal:2000;
  const protein_goal=setup?setup.protein:150;
  const carbs_goal=setup?setup.carbs:200;
  const fat_goal=setup?setup.fat:60;
  let eaten=0,protein=0,carbs=0,fat=0;
  (dayLog.meals||[]).forEach(m=>{eaten+=m.cals;protein+=m.protein||0;carbs+=m.carbs||0;fat+=m.fat||0;});
  const remaining=Math.max(0,goal-eaten);
  const pct=Math.min(100,(eaten/goal)*100);
  const C=2*Math.PI*50;
  document.getElementById('ring-fill').style.strokeDashoffset=C-(pct/100)*C;
  document.getElementById('ring-remaining').textContent=remaining;
  document.getElementById('stat-goal').textContent=goal;
  document.getElementById('stat-eaten').textContent=eaten;
  document.getElementById('stat-remaining').textContent=remaining;
  document.getElementById('today-date').textContent=fmtDate(key);
  // Macros
  document.getElementById('mac-protein').textContent=`${Math.round(protein)} / ${protein_goal} جم`;
  document.getElementById('mac-carbs').textContent=`${Math.round(carbs)} / ${carbs_goal} جم`;
  document.getElementById('mac-fat').textContent=`${Math.round(fat)} / ${fat_goal} جم`;
  document.getElementById('mac-bar-protein').style.width=Math.min(100,(protein/protein_goal)*100)+'%';
  document.getElementById('mac-bar-carbs').style.width=Math.min(100,(carbs/carbs_goal)*100)+'%';
  document.getElementById('mac-bar-fat').style.width=Math.min(100,(fat/fat_goal)*100)+'%';
  // Meals
  const meals=dayLog.meals||[];
  document.getElementById('meals-count').textContent=meals.length?`(${meals.length})`:'';
  const list=document.getElementById('meals-list');
  if(!meals.length){
    list.innerHTML=`<div class="empty-meals"><div class="em-icon">🍽️</div>لم تسجل أي وجبة اليوم</div>`;
    return;
  }
  list.innerHTML=meals.map((m,i)=>`<div class="meal-item"><span class="meal-icon">${m.emoji}</span><div class="meal-info"><div class="meal-name">${m.name}${m.qty>1?` ×${m.qty}`:''}</div><div class="meal-time">${m.mealTime} · ${m.time}</div></div><span class="meal-cals">${m.cals} ك</span><button class="meal-del" onclick="deleteMeal(${i})">🗑️</button></div>`).join('');
}
function deleteMeal(idx){
  const key=todayKey();
  if(!log[key])return;
  log[key].meals.splice(idx,1);
  saveLog();renderToday();renderHistory();
  toast('🗑️ تم الحذف');
}

// ══ ADD MEAL MODAL ══════════════════════════════════════
function openAddMeal(){
  selectedModalFood=null;
  document.getElementById('modal-search').value='';
  document.getElementById('meal-qty').value=1;
  filterModalFoods();
  document.getElementById('meal-modal').classList.remove('hidden');
}
function closeAddMeal(){document.getElementById('meal-modal').classList.add('hidden');selectedModalFood=null;}
function filterModalFoods(){
  const q=(document.getElementById('modal-search').value||'').toLowerCase();
  const list=document.getElementById('modal-food-list');
  const filtered=foodDB.filter(f=>!q||f.name.toLowerCase().includes(q)||f.cat.toLowerCase().includes(q));
  list.innerHTML=filtered.slice(0,20).map(f=>`<div class="modal-food-item ${selectedModalFood&&selectedModalFood.id===f.id?'sel':''}" onclick="selModalFood('${f.id}')"><span class="mfi-emoji">${f.emoji||'🍽️'}</span><span class="mfi-name">${f.name}</span><span class="mfi-cals">${f.cals} ك</span></div>`).join('');
}
function selModalFood(id){
  selectedModalFood=foodDB.find(f=>f.id===id);
  filterModalFoods();
}
function addMeal(){
  if(!selectedModalFood){toast('❌ اختر طعاماً أولاً','err');return;}
  const qty=parseFloat(document.getElementById('meal-qty').value)||1;
  const mealTime=document.getElementById('meal-time').value;
  const key=todayKey();
  if(!log[key])log[key]={meals:[]};
  log[key].meals.push({
    id:'m_'+Date.now(),
    name:selectedModalFood.name,
    emoji:selectedModalFood.emoji||'🍽️',
    cals:Math.round(selectedModalFood.cals*qty),
    protein:Math.round((selectedModalFood.protein||0)*qty),
    carbs:Math.round((selectedModalFood.carbs||0)*qty),
    fat:Math.round((selectedModalFood.fat||0)*qty),
    qty,mealTime,
    time:nowTime(),
  });
  saveLog();closeAddMeal();renderToday();renderHistory();
  toast(`✅ تمت إضافة ${selectedModalFood.name}`,'ok');
}

// ══ FOOD DB ═════════════════════════════════════════════
function renderFoodDB(){
  const q=(document.getElementById('food-search-inp').value||'').toLowerCase();
  const cats={};
  foodDB.filter(f=>!q||f.name.toLowerCase().includes(q)||f.cat.toLowerCase().includes(q)).forEach(f=>{
    if(!cats[f.cat])cats[f.cat]=[];cats[f.cat].push(f);
  });
  const el=document.getElementById('food-db-list');
  el.innerHTML=Object.entries(cats).map(([cat,foods])=>`<div class="food-category"><h3>${cat}</h3><div class="food-grid">${foods.map(f=>`<div class="food-card" onclick="quickAddFood('${f.id}')"><div class="food-emoji">${f.emoji||'🍽️'}</div><div class="food-name">${f.name}</div><div class="food-cals-badge">${f.cals}</div><div class="food-per">سعرة/حصة</div></div>`).join('')}</div></div>`).join('');
}
function quickAddFood(id){
  selectedModalFood=foodDB.find(f=>f.id===id);
  if(!selectedModalFood)return;
  const key=todayKey();
  if(!log[key])log[key]={meals:[]};
  log[key].meals.push({
    id:'m_'+Date.now(),
    name:selectedModalFood.name,
    emoji:selectedModalFood.emoji||'🍽️',
    cals:selectedModalFood.cals,
    protein:selectedModalFood.protein||0,
    carbs:selectedModalFood.carbs||0,
    fat:selectedModalFood.fat||0,
    qty:1,mealTime:'وجبة خفيفة',
    time:nowTime(),
  });
  saveLog();renderToday();renderHistory();
  toast(`✅ أُضيف: ${selectedModalFood.name}`,'ok');
}
function addCustomFood(){
  const name=document.getElementById('cf-name').value.trim();
  const cals=parseInt(document.getElementById('cf-cals').value)||0;
  if(!name||!cals){toast('❌ الاسم والسعرات مطلوبة','err');return;}
  const protein=parseInt(document.getElementById('cf-protein').value)||0;
  const carbs=parseInt(document.getElementById('cf-carbs').value)||0;
  const fat=parseInt(document.getElementById('cf-fat').value)||0;
  const emojis=['🍽️','🥘','🫕','🍱','🥗','🍜'];
  foodDB.push({id:'cf_'+Date.now(),cat:'⭐ أطعمتي المخصصة',emoji:emojis[Math.floor(Math.random()*emojis.length)],name,cals,protein,carbs,fat});
  saveFood();
  document.getElementById('cf-name').value='';document.getElementById('cf-cals').value='';
  document.getElementById('cf-protein').value='';document.getElementById('cf-carbs').value='';document.getElementById('cf-fat').value='';
  renderFoodDB();toast(`✅ تم إضافة ${name}`,'ok');
}

// ══ HISTORY ═════════════════════════════════════════════
function renderHistory(){
  const goal=setup?setup.goal:2000;
  const days=Object.keys(log).sort((a,b)=>b.localeCompare(a));
  const list=document.getElementById('history-list');
  if(!days.length){list.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);">لا يوجد سجل بعد 📭</div>';return;}
  // Stats
  let totalCals=0,streak=0;
  const sorted=[...days].sort((a,b)=>b.localeCompare(a));
  sorted.forEach(d=>{const m=log[d].meals||[];const c=m.reduce((a,x)=>a+x.cals,0);totalCals+=c;});
  const avg=days.length?Math.round(totalCals/days.length):0;
  // Streak
  let sd=new Date();
  for(let i=0;i<30;i++){const k=sd.toISOString().split('T')[0];if(log[k]&&(log[k].meals||[]).length){streak++;sd.setDate(sd.getDate()-1);}else break;}
  document.getElementById('hs-days').textContent=days.length;
  document.getElementById('hs-avg').textContent=avg;
  document.getElementById('hs-streak').textContent=streak;
  list.innerHTML=days.slice(0,30).map(d=>{
    const meals=log[d].meals||[];
    const cals=meals.reduce((a,m)=>a+m.cals,0);
    const pct=Math.min(100,(cals/goal)*100);
    const over=cals>goal;
    const dte=new Date(d);
    return`<div class="history-item"><div class="hi-date"><span class="day">${dte.getDate()}</span>${dte.toLocaleDateString('ar-SA',{month:'short'})}</div><div class="hi-bar-wrap"><div class="hi-title">${dte.toLocaleDateString('ar-SA',{weekday:'long'})}</div><div class="hi-bar-bg"><div class="hi-bar" style="width:${pct}%;background:${over?'linear-gradient(90deg,#ff9f43,#e74c3c)':'linear-gradient(90deg,var(--accent),var(--green))'}"></div></div></div><div class="hi-cals" style="color:${over?'#ff9f43':'var(--green)'}"><span style="font-family:Tajawal;font-size:18px;font-weight:800">${cals}</span><br/><span class="hi-status" style="color:var(--muted)">${over?'⬆️ زيادة':'✅ ضمن الهدف'}</span></div></div>`;
  }).join('');
}

// ══ NAV ═════════════════════════════════════════════════
function showPage(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  if(btn)btn.classList.add('active');
